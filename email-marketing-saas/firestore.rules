rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users: only the authenticated user can read/write their own doc ──────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── WhatsApp Sessions ────────────────────────────────────────────────────
    match /whatsapp_sessions/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Scraping Campaigns ───────────────────────────────────────────────────
    match /campaigns/{campaignId} {
      allow read, write: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
    }

    // ── Leads (subcollection under campaigns) ────────────────────────────────
    match /campaigns/{campaignId}/leads/{leadId} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/campaigns/$(campaignId)).data.userId
          == request.auth.uid;
    }

    // ── Outreach logs ────────────────────────────────────────────────────────
    match /outreach_logs/{logId} {
      allow read, write: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
    }
  }
}
