# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Supabase (replaces Firebase) ──────────────────────────────────────────────
# Find these in your Supabase project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key   # NEVER expose this to the browser

# ── System Email (Brevo / Sendinblue) ─────────────────────────────────────────
# This is the fallback key used when users choose "system" SMTP
# Get it from: https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-your-admin-brevo-api-key

# ── AI — Groq ────────────────────────────────────────────────────────────────
# Get it from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key

# ── Scraper ───────────────────────────────────────────────────────────────────
SCRAPER_CONCURRENCY=3
SCRAPER_REQUEST_DELAY_MS=2000

# ── Email Send Throttle ───────────────────────────────────────────────────────
# Milliseconds to wait between each email send (avoids rate limits)
EMAIL_SEND_DELAY_MS=1500

# ── WhatsApp Session Storage ──────────────────────────────────────────────────
WA_SESSION_BASE_DIR=./sessions

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# USER-CONFIGURABLE SMTP (stored per-user in Supabase profiles table)
# Users add these via the Settings page — NOT in this file.
# Available providers: brevo | sendgrid | mailgun | smtp | system
#
# Brevo:    brevo_api_key
# SendGrid: sendgrid_api_key
# Mailgun:  mailgun_api_key + mailgun_domain
# SMTP:     smtp_host, smtp_port, smtp_user, smtp_pass, smtp_secure
# ─────────────────────────────────────────────────────────────────────────────
